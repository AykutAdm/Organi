@model List<RecentProductDto>
<div class="table-card">
    <div class="table-header">
        <div class="chart-title">Recent Products</div>
        <a class="btn-sm" href="/Admin/Product/ProductList">View all →</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>Product</th>
                <th>Category</th>
                <th style="text-align:right">Price</th>
                <th style="text-align:right">Stock</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="td-img">
                            <div class="prod-thumb"><img src="@item.ImageUrl" alt="@item.Name" /></div>
                            <div class="prod-name">@item.Name</div>
                        </div>
                    </td>
                    <td style="color:var(--text-secondary);font-size:12px">@item.CategoryName</td>
                    <td style="text-align:right;color:var(--accent-text);font-weight:500">$@item.Price</td>
                    <td style="text-align:right">@item.Stock</td>
                    <td>
                        @if (item.Stock > 30)
                        {
                            <span class="status-pill active">In Stock</span>
                        }
                        else
                        {
                            <span class="status-pill low">Low Stock</span>
                        }
                    </td>
                </tr>
            }

        </tbody>
    </table>
</div>