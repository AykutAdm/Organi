@model ResultDashboardStatsDto

<!-- STAT CARDS -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon-wrap green">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2"><path d="M20 7H4a1 1 0 00-1 1v10a1 1 0 001 1h16a1 1 0 001-1V8a1 1 0 00-1-1z" /><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" /></svg>
            </div>
            <span class="stat-change up">↑ 12%</span>
        </div>
        <div class="stat-val">@Model.TotalProducts</div>
        <div class="stat-label">Total Products</div>
        <div class="spark-row">
            <div class="spark-bar" style="flex:3"></div><div class="spark-bar" style="flex:5"></div>
            <div class="spark-bar" style="flex:4"></div><div class="spark-bar" style="flex:7"></div>
            <div class="spark-bar" style="flex:6"></div><div class="spark-bar" style="flex:8;background:var(--accent);opacity:.4"></div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon-wrap gold">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c8a84b" stroke-width="2"><path d="M4 6h16M4 10h16M4 14h10M4 18h6" /></svg>
            </div>
            <span class="stat-change up">↑ 8%</span>
        </div>
        <div class="stat-val">@Model.TotalCategories</div>
        <div class="stat-label">Categories</div>
        <div class="spark-row">
            <div class="spark-bar" style="flex:5;background:var(--gold-dim)"></div><div class="spark-bar" style="flex:3;background:var(--gold-dim)"></div>
            <div class="spark-bar" style="flex:7;background:var(--gold-dim)"></div><div class="spark-bar" style="flex:4;background:var(--gold-dim)"></div>
            <div class="spark-bar" style="flex:6;background:var(--gold-dim)"></div><div class="spark-bar" style="flex:8;background:var(--gold);opacity:.4"></div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon-wrap blue">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#5b9bd5" stroke-width="2"><circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" /><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6" /></svg>
            </div>
            <span class="stat-change up">↑ 24%</span>
        </div>
        <div class="stat-val">@Model.BasketItems</div>
        <div class="stat-label">Basket Items</div>
        <div class="spark-row">
            <div class="spark-bar" style="flex:2;background:var(--blue-dim)"></div><div class="spark-bar" style="flex:6;background:var(--blue-dim)"></div>
            <div class="spark-bar" style="flex:4;background:var(--blue-dim)"></div><div class="spark-bar" style="flex:8;background:var(--blue-dim)"></div>
            <div class="spark-bar" style="flex:5;background:var(--blue-dim)"></div><div class="spark-bar" style="flex:9;background:var(--blue);opacity:.4"></div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon-wrap red">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e05252" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
            </div>
            <span class="stat-change down">↓ 3%</span>
        </div>
        <div class="stat-val">@Model.LowStockItems</div>
        <div class="stat-label">Low Stock Items</div>
        <div class="spark-row">
            <div class="spark-bar" style="flex:6;background:var(--red-dim)"></div><div class="spark-bar" style="flex:8;background:var(--red-dim)"></div>
            <div class="spark-bar" style="flex:5;background:var(--red-dim)"></div><div class="spark-bar" style="flex:9;background:var(--red-dim)"></div>
            <div class="spark-bar" style="flex:7;background:var(--red-dim)"></div><div class="spark-bar" style="flex:6;background:var(--red);opacity:.4"></div>
        </div>
    </div>
</div>