@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Organi Admin — Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/organi-admin/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/organi-admin/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/organi-admin/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/organi-admin/css/admin-pages.css" asp-append-version="true" />
</head>
<body>

    <!-- ========== SIDEBAR ========== -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-mark">O</div>
            <div>
                <div class="logo-text">Organi</div>
                <div class="logo-sub">Admin</div>
            </div>
        </div>

        <div class="sidebar-section">
            <div class="sidebar-label" style="margin-top:4px">Overview</div>
            <a class="nav-item active" href="/Admin/Dashboard/Index">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1.5" /><rect x="14" y="3" width="7" height="7" rx="1.5" /><rect x="3" y="14" width="7" height="7" rx="1.5" /><rect x="14" y="14" width="7" height="7" rx="1.5" /></svg>
                <span class="nav-text">Dashboard</span>
            </a>

            <div class="sidebar-label" style="margin-top:16px">Catalog</div>
            <a class="nav-item" href="/Admin/Product/ProductList">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 7H4a1 1 0 00-1 1v10a1 1 0 001 1h16a1 1 0 001-1V8a1 1 0 00-1-1z" /><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" /></svg>
                <span class="nav-text">Products</span>
            </a>
            <a class="nav-item" href="/Admin/Category/CategoryList">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 6h16M4 10h16M4 14h10M4 18h6" /></svg>
                <span class="nav-text">Categories</span>
            </a>
            <a class="nav-item" href="/Admin/ProductNutrition/ProductNutritionList">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10" /><path d="M12 8v4l3 3" /></svg>
                <span class="nav-text">Nutritions</span>
            </a>

            <a class="nav-item" href="/Admin/About/AboutList">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
                <span class="nav-text">About</span>
            </a>

            <a class="nav-item" href="/Admin/Slider/SliderList">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
                <span class="nav-text">Slider</span>
            </a>

            <a class="nav-item" href="/Admin/Testimonial/TestimonialList">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
                <span class="nav-text">Testimonial</span>
            </a>


        </div>

        <div class="sidebar-footer">
            <div class="user-row">
                <div class="user-avatar">AD</div>
                <div>
                    <div class="user-name">Admin</div>
                </div>
                <svg style="margin-left:auto;opacity:.4;flex-shrink:0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6" /></svg>
            </div>
        </div>
    </aside>

    <!-- ========== MAIN ========== -->
    <div class="main">
        <div class="topbar">
            <div class="topbar-left">
                <div class="page-title">@(ViewData["PageTitle"] ?? "Dashboard")</div>
                <div class="page-sub">@(ViewData["PageSub"] ?? "Welcome back, Admin · Today")</div>
            </div>
            <div class="topbar-right">
                @RenderSection("TopbarRight", required: false)
                <div class="search-box">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    Search...
                </div>
                <div class="notif-btn">
                    <div class="notif-dot"></div>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 01-3.46 0" /></svg>
                </div>
            </div>
        </div>

        <div class="content">

            @RenderBody()

        </div>
    </div>

    <script src="/organi-admin/js/sidebar.js"></script>
    <script src="/organi-admin/js/charts.js"></script>
    <script src="/organi-admin/js/search.js"></script>
</body>
</html>
