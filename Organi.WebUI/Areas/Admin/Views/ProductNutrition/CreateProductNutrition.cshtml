@model CreateProductNutritionDto

@{
    ViewData["Title"] = "CreateProductNutrition";
    ViewData["PageTitle"] = "Add Nutrition";
    ViewData["PageSub"] = "Add nutrition info for a product";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var products = (List<ResultProductDto>)ViewBag.Products;
}

@section TopbarRight {
    <a class="btn-ghost" href="/Admin/ProductNutrition/ProductNutritionList" style="font-size:12px;padding:7px 16px">← Back to Nutritions</a>
}

<div class="admin-page admin-form-page">
    <div class="form-card form-card-wide">
        <div class="form-title">Nutrition Details</div>
        <form method="post" action="/Admin/ProductNutrition/CreateProductNutrition">
            <div class="form-grid">
                <div class="form-group span-2">
                    <label class="form-label" for="ProductId">Product</label>
                    <select class="form-select" id="ProductId" asp-for="ProductId">
                        @foreach (var product in products)
                        {
                            <option value="@product.ProductId">@product.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" for="ServingSize">Serving Size</label>
                    <input class="form-input" type="text" id="ServingSize" asp-for="ServingSize" placeholder="e.g. Per 100g" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="Energy">Energy</label>
                    <input class="form-input" type="text" id="Energy" asp-for="Energy" placeholder="e.g. 41 kcal" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="Fat">Fat</label>
                    <input class="form-input" type="text" id="Fat" asp-for="Fat" placeholder="e.g. 0.2g" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="Protein">Protein (g)</label>
                    <input class="form-input" type="number" step="0.1" id="Protein" asp-for="Protein" placeholder="0.0" />
                </div>
                <div class="form-group" style="justify-content:flex-end;padding-top:24px">
                    <label class="form-label" for="Carbohydrates" style="display:flex;align-items:center;gap:8px;text-transform:none;font-size:13px;color:var(--text-secondary)">
                        <input type="checkbox" id="Carbohydrates" asp-for="Carbohydrates" style="width:16px;height:16px;accent-color:var(--accent)" />
                        Has Carbohydrates
                    </label>
                </div>
                <div class="form-group span-2">
                    <label class="form-label" for="Note">Note</label>
                    <textarea class="form-textarea" id="Note" asp-for="Note" placeholder="Optional note..."></textarea>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-primary">Save Nutrition</button>
                <a class="btn-ghost" href="/Admin/ProductNutrition/ProductNutritionList">Cancel</a>
            </div>
        </form>
    </div>
</div>
