@model List<ResultProductDto>
@using Organi.WebUI.DTOs.CategoryDtos
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}


<!-- main body start -->
<main>

    <!-- sidebar section start -->
    <section class="sidebar_section">
        <div class="sidebar_content_wrap">
            <div class="container">
                <div class="row">
                    <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasRight"
                         aria-labelledby="offcanvasRightLabel">
                        <div class="offcanvas-header align-items-center">
                            <h5 class="mb-0">Organic Products</h5>
                            <button type="button" class="btn-close text-reset text-end" data-bs-dismiss="offcanvas"
                                    aria-label="Close"></button>
                        </div>
                        <div class="offcanvas-body">
                            <!-- Dinamik son eklenen ürünler gösterilecek -->
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var recentProduct in Model.Take(3))
                                {
                                    <div class="prdc_ctg_product_content mt-1 d-flex align-items-center">
                                        <div class="prdc_ctg_product_img d-flex justify-content-center align-items-center me-3">
                                            <img src="@recentProduct.ImageUrl" alt="@recentProduct.Name" style="width: 50px; height: 50px; object-fit: cover;">
                                        </div>
                                        <div class="prdc_ctg_product_text">
                                            <div class="prdc_ctg_product_title my-2">
                                                <h5>@recentProduct.Name</h5>
                                            </div>
                                            <div class="prdc_ctg_product_price mt-1 product_price">
                                                <span class="sale_price pe-1">$@recentProduct.Price.ToString("F2")</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            <div class="total_price">
                                @if (Model != null && Model.Any())
                                {
                                    var subtotal = Model.Sum(x => x.Price);
                                    var vat = subtotal * 0.05m;
                                    var discount = subtotal * 0.15m;
                                    var total = subtotal + vat - discount;

                                    <ul class="ul_li_block mb_30 clearfix">
                                        <li>
                                            <span>Subtotal:</span>
                                            <span>$@subtotal.ToString("F2")</span>
                                        </li>
                                        <li>
                                            <span>Vat 5%:</span>
                                            <span>$@vat.ToString("F2")</span>
                                        </li>
                                        <li>
                                            <span>Discount 15%:</span>
                                            <span>- $@discount.ToString("F2")</span>
                                        </li>
                                        <li>
                                            <span>Total:</span>
                                            <span>$@total.ToString("F2")</span>
                                        </li>
                                    </ul>
                                }
                            </div>
                            <div class="sidebar_btns">
                                <ul class="btns_group ul_li_block clearfix">
                                    <li><a href="cart.html">View Cart</a></li>
                                    <li><a href="checkout.html">Checkout</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- sidebar section end -->
    <!-- Breadcrumb section start -->
    <section class="breadcrumb_sec_1 position-relative">
        <div class="breadcrumb_wrap sec_space_mid_small"
             style="background-image: url(/organic-html/assets/images/breadcrumb/breadcrumb1.png);">
            <div class="breadcrumb_cont text-center">
                <div class="breadcrumb_title">
                    <h2 class="text-white">Shop List Sidebar</h2>
                </div>
                <ul class="list-unstyled breadcrumb_item d-flex justify-content-center align-items-center text-white">
                    <li><a href="index.html"><i class="fas fa-home active"></i>Home</a></li>
                    <li><i class="fas fa-chevron-right"></i>About</li>
                    <li><i class="fas fa-chevron-right"></i>Dried</li>
                </ul>
            </div>
        </div>
    </section>
    <!-- Breadcrumb section end -->
    <!-- shop list sidebar start -->
    <section class="shop_list_sidebar sec_space_large">
        <div class="shop_sidebar_wrap">
            <div class="container">
                <div class="row">
                    <div class="col-lg-3">
                        <form method="get" action="/Product/FilterProducts" id="filterForm">
                            <div class="shop_sidebar_searchbar position-relative">
                                <input class="rounded-pill" type="search" name="searchTerm" placeholder="Search" value="@ViewContext.HttpContext.Request.Query["searchTerm"]">
                                <i class="fas fa-search position-absolute"></i>
                            </div>
                            <!-- blog category start -->
                            <div class="blog_category" data-aos="fade-up" data-aos-duration="2000">
                                <div class="blog_category_wrap">
                                    <h3 class="blog_category_title py-3">Categories</h3>
                                    <div class="blog_category_item">
                                        <div class="row">
                                            <div class="form-check">
                                                @foreach (var category in (List<ResultCategoryDto>)ViewBag.Categories)
                                                {
                                                    <div class="col">
                                                        <input class="form-check-input" type="radio" name="categoryId"
                                                               value="@category.CategoryId" id="category_@category.CategoryId"
                                                               @(ViewContext.HttpContext.Request.Query["categoryId"] == category.CategoryId.ToString() ? "checked" : "")>
                                                        <label class="form-check-label ms-2" for="category_@category.CategoryId">
                                                            @category.Name
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- blog category end -->
                            <!-- filter range start -->
                            <div class="price-range-area mt-3" data-aos="fade-up" data-aos-duration="2000">
                                <h3 class="price_range_title mb-4">Filter By Price</h3>
                                <div class="row">
                                    <div class="col-6">
                                        <input type="number" name="minPrice" class="form-control" placeholder="Min Price"
                                               value="@ViewContext.HttpContext.Request.Query["minPrice"]" step="0.01">
                                    </div>
                                    <div class="col-6">
                                        <input type="number" name="maxPrice" class="form-control" placeholder="Max Price"
                                               value="@ViewContext.HttpContext.Request.Query["maxPrice"]" step="0.01">
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="fas fa-search"></i> Filter Products
                                    </button>
                                    <a href="/Product/Index" class="btn btn-secondary w-100 mt-2">
                                        <i class="fas fa-times"></i> Clear Filters
                                    </a>
                                </div>
                            </div>
                        </form>
                        <!-- filter range end -->

                    </div>
                    <div class="col-lg-9">
                        <!-- shop list section start -->
                        <section class="shop_list_sec" data-aos="fade-up" data-aos-duration="2000">
                            <div class="shop_list_wrap">
                                <div class="container">
                                    <div class="filter_area d-flex justify-content-between align-items-center mb_30">
                                        <ul class="nav layout_tab_nav ul_li" role="tablist">
                                            <li>
                                                <button class="active" data-bs-toggle="tab" data-bs-target="#grid_layout"
                                                        type="button" role="tab" aria-selected="true">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17"
                                                         viewBox="0 0 12 12">
                                                        <path id="grid" class="cls-1"
                                                              d="M1784,905h2v2h-2v-2Zm5,0h2v2h-2v-2Zm5,0h2v2h-2v-2Zm-10,5h2v2h-2v-2Zm5,0h2v2h-2v-2Zm5,0h2v2h-2v-2Zm-10,5h2v2h-2v-2Zm5,0h2v2h-2v-2Zm5,0h2v2h-2v-2Z"
                                                              transform="translate(-1784 -905)" />
                                                    </svg>
                                                </button>
                                            </li>
                                            <li>
                                                <button data-bs-toggle="tab" data-bs-target="#list_layout" type="button"
                                                        role="tab" aria-selected="false">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17"
                                                         viewBox="0 0 12 12">
                                                        <path id="list" class="cls-1"
                                                              d="M1823,905h2v2h-2v-2Zm5,0h2v2h-2v-2Zm5,0h2v2h-2v-2Zm-10,5h2v2h-2v-2Zm5,0h2v2h-2v-2Zm5,0h2v2h-2v-2Zm-10,5h2v2h-2v-2Zm5,0h2v2h-2v-2Zm5,0h2v2h-2v-2Zm-5-10h7v2h-7v-2Zm0,5h7v2h-7v-2Zm0,5h7v2h-7v-2Z"
                                                              transform="translate(-1823 -905)" />
                                                    </svg>
                                                </button>
                                            </li>
                                            <span class="show_result">Showing 1–18 of 24 results</span>
                                        </ul>
                                        <form action="#">
                                            <div class="sorting_from d-flex align-items-center">
                                                <span class="sorting_from_title">Default Sorting:</span>
                                                <div class=" clearfix">
                                                    <select>
                                                        <option data-display="Select">Nothing</option>
                                                        <option value="1" selected>Popularity</option>
                                                        <option value="2">Organic</option>
                                                        <option value="4">Fantastic</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                    <div class="shop_product_list">
                                        <div class="tab-content" id="pills-tabContent">
                                            <div class="tab-pane fade show active" id="grid_layout" role="tabpanel"
                                                 aria-labelledby="pills-grid_layout-tab">
                                                <div class="row g-4">
                                                    @foreach (var item in Model)
                                                    {
                                                        <div class="col-sm-6 col-lg-4">
                                                            <div class="product_layout_1 overflow-hidden position-relative">
                                                                <div class="product_layout_content bg-white position-relative">
                                                                    <div class="product_image_wrap">
                                                                        <a class="product_image d-flex justify-content-center align-items-center"
                                                                           href="product-detail.html" target="_blank">
                                                                            <img class="pic-1" src="@item.ImageUrl"
                                                                                 alt="image_not_found">
                                                                            <img class="pic-2" src="@item.ImageUrl"
                                                                                 alt="image_not_found">
                                                                        </a>
                                                                        <ul class="product_badge_group ul_li_block">
                                                                            <li>
                                                                                <span class="product_badge badge_meats position-absolute rounded-pill text-uppercase">@item.CategoryName</span>
                                                                            </li>
                                                                        </ul>
                                                                        <ul class="product_action_btns ul_li_block d-flex">
                                                                            <li>
                                                                                <a class="tooltips" data-placement="top"
                                                                                   title="Search Product" href="#!">
                                                                                    <i class="fas fa-search"></i>
                                                                                </a>
                                                                            </li>
                                                                            <li>
                                                                                <form method="post" action="/Basket/AddToBasket" style="display: inline;">
                                                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                                                    <input type="hidden" name="quantity" value="1" />
                                                                                    <button type="submit" class="tooltips border-0 bg-transparent"
                                                                                            data-placement="top" title="Add To Cart">
                                                                                        <i class="fas fa-shopping-bag"></i>
                                                                                    </button>
                                                                                </form>
                                                                            </li>
                                                                        </ul>
                                                                    </div>
                                                                    <div class="rating_wrap d-flex">
                                                                        <ul class="rating_star ul_li">
                                                                            <li class="active"><i class="fas fa-star"></i></li>
                                                                            <li class="active"><i class="fas fa-star"></i></li>
                                                                            <li class="active"><i class="fas fa-star"></i></li>
                                                                            <li class="active"><i class="fas fa-star"></i></li>
                                                                            <li><i class="far fa-star"></i></li>
                                                                        </ul>
                                                                        <span class="shop_review_text">( 4.0 )</span>
                                                                    </div>
                                                                    <div class="product_content">
                                                                        <h3 class="product_title">
                                                                            <a href="product-detail.html" target="_blank">@item.Name</a>
                                                                        </h3>
                                                                        <div class="product_price">
                                                                            <span class="sale_price pe-1">$@item.Price.ToString("F2")</span>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }

                                                </div>
                                            </div>
                                            <!-- list layout start  -->

                                        </div>
                                    </div>

                                </div>
                            </div>
                        </section>
                        <!-- shop list section end -->
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- shop list sidebar end -->



</main>

