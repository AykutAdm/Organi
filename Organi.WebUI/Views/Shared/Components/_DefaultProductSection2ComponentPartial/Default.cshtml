@model List<ResultAboutDto>
<!-- product section-2 start -->
<section class="product_section_2 sec_space_xms_60" data-aos="fade-up" data-aos-duration="2000">
    <div class="product_section_2_wrap">
        @foreach (var item in Model)
        {
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <div class="product_gallery" data-aos="fade-up" data-aos-duration="1000">
                            <img src="@item.ImageUrl" alt="image_not_found">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="product_section_content" data-aos="fade-up" data-aos-duration="2000">
                            <div class="product_sec_sub_title d-flex align-items-center pb-2">
                                <i class="far fa-circle"></i>
                                <i class="far fa-circle"></i>
                                <i class="far fa-circle"></i>
                                <span class="ps-1">FRESH FROM OUR FARM</span>
                            </div>
                            <div class="product_section_title py-2">
                                <h2>@item.Title</h2>
                            </div>
                            <div class="product_section_subtitle position-relative">
                                <p class="pb-0">
                                    @item.SubTitle
                                </p>
                            </div>
                            <div class="product_section_desc">
                                <p>
                                    @item.Description
                                </p>
                            </div>
                            <div class="product_section_btn">
                                <a href="#!">
                                    <button type="button"
                                            class="btn custom_btn load_more_1 rounded-pill px-5 py-3 text-white">
                                        Subscribe
                                        <i class="fas fa-long-arrow-alt-right"></i>
                                    </button>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
<!-- product section-2 end -->
