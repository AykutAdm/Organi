@model List<ResultProductDto>

@{
    var categoryTabs = Model.GroupBy(p => p.CategoryId).Select(g => g.First()).ToList();
}

<section class="product_section3" data-aos="fade-up" data-aos-duration="2000">
    <div class="product_section3_wrap inner_p_all_40 position-relative">
        <div class="container">
            <div class="product_sec_content_wrap position-relative overflow-hidden shadow inner_p_all_100 bg-white">
                <div class="team_top_content text-center">
                    <div class="offer_sub_title d-flex align-items-center justify-content-center pb-2">
                        <i class="far fa-circle"></i>
                        <i class="far fa-circle"></i>
                        <i class="far fa-circle"></i>
                        <span class="text-uppercase px-3">FRESH FROM OUR FARM</span>
                        <i class="far fa-circle"></i>
                        <i class="far fa-circle"></i>
                        <i class="far fa-circle"></i>
                    </div>
                    <div class="product_top_title text-center py-1">
                        <h2>Good Organic Products</h2>
                    </div>
                    <div class="d-flex justify-content-center align-items-center flex-wrap">
                        <ul class="product_tabnav_3 nav nav-pills mb-4 mt-3 flex-wrap justify-content-center"
                            id="pills-tab"
                            role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active @(categoryTabs.Count == 0 ? "first_btn last_btn" : "first_btn") text-uppercase"
                                        id="pills-all-tab"
                                        data-bs-toggle="pill"
                                        data-bs-target="#pills-all"
                                        type="button"
                                        role="tab"
                                        aria-controls="pills-all"
                                        aria-selected="true">
                                    All
                                </button>
                            </li>
                            @for (var i = 0; i < categoryTabs.Count; i++)
                            {
                                var cat = categoryTabs[i];
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link text-uppercase @(i == categoryTabs.Count - 1 ? "last_btn" : "")"
                                            id="pills-cat-@cat.CategoryId-tab"
                                            data-bs-toggle="pill"
                                            data-bs-target="#pills-cat-@cat.CategoryId"
                                            type="button"
                                            role="tab"
                                            aria-controls="pills-cat-@cat.CategoryId"
                                            aria-selected="false">
                                        @cat.CategoryName
                                    </button>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
                <div class="tab-content" id="pills-tabContent">
                    <div class="tab-pane fade show active" id="pills-all" role="tabpanel"
                         aria-labelledby="pills-all-tab">
                        <div class="row g-4">
                            @foreach (var item in Model)
                            {
                                <div class="col-sm-6 col-lg-4">
                                    <div class="product_ctg_content_3 d-flex justify-content-center align-items-center position-relative">
                                        <div class="prdc_ctg_product_img d-flex justify-content-center align-items-center me-3">
                                            <img src="@item.ImageUrl"
                                                 alt="image_not_found">
                                        </div>
                                        <div class="prdc_ctg_product_text">
                                            <div class="prdc_ctg_product_rating my-1 rating_wrap d-flex">
                                                <ul class="rating_star ul_li">
                                                    <li class="active"><i class="fas fa-star"></i></li>
                                                    <li class="active"><i class="fas fa-star"></i></li>
                                                    <li class="active"><i class="fas fa-star"></i></li>
                                                    <li class="active"><i class="fas fa-star"></i></li>
                                                    <li><i class="far fa-star"></i></li>
                                                </ul>
                                                <span class="shop_review_text">( 4.0 )</span>
                                            </div>
                                            <div class="prdc_ctg_product_title my-2">
                                                <a href="shop-list.html">
                                                    <h5>@item.Name</h5>
                                                </a>
                                            </div>
                                            <div class="prdc_ctg_product_meta my-1 small text-muted">
                                                @item.CategoryName
                                            </div>
                                            <div class="prdc_ctg_product_price mt-1 product_price">
                                                <span class="sale_price pe-1">$@item.Price.ToString("F2")</span>
                                            </div>
                                            <ul class="product_action_btns ul_li_block d-flex">
                                                <li>
                                                    <a data-bs-toggle="tooltip" data-bs-placement="top" title="Search Product"
                                                       href="#!"><i class="fas fa-search"></i></a>
                                                </li>
                                                <li>
                                                    <a data-bs-toggle="tooltip" data-bs-placement="top" title="Add To Cart"
                                                       href="#product_quick_view" data-bs-toggle="modal">
                                                        <i class="fas fa-shopping-bag"></i>
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    @for (var i = 0; i < categoryTabs.Count; i++)
                    {
                        var cat = categoryTabs[i];
                        <div class="tab-pane fade" id="pills-cat-@cat.CategoryId"
                             role="tabpanel"
                             aria-labelledby="pills-cat-@cat.CategoryId-tab">
                            <div class="row g-4">
                                @foreach (var item in Model.Where(p => p.CategoryId == cat.CategoryId))
                                {
                                    <div class="col-sm-6 col-lg-4">
                                        <div class="product_ctg_content_3 d-flex justify-content-center align-items-center position-relative">
                                            <div class="prdc_ctg_product_img d-flex justify-content-center align-items-center me-3">
                                                <img src="@item.ImageUrl"
                                                     alt="image_not_found">
                                            </div>
                                            <div class="prdc_ctg_product_text">
                                                <div class="prdc_ctg_product_rating my-1 rating_wrap d-flex">
                                                    <ul class="rating_star ul_li">
                                                        <li class="active"><i class="fas fa-star"></i></li>
                                                        <li class="active"><i class="fas fa-star"></i></li>
                                                        <li class="active"><i class="fas fa-star"></i></li>
                                                        <li class="active"><i class="fas fa-star"></i></li>
                                                        <li><i class="far fa-star"></i></li>
                                                    </ul>
                                                    <span class="shop_review_text">( 4.0 )</span>
                                                </div>
                                                <div class="prdc_ctg_product_title my-2">
                                                    <a href="shop-list.html">
                                                        <h5>@item.Name</h5>
                                                    </a>
                                                </div>
                                                <div class="prdc_ctg_product_meta my-1 small text-muted">
                                                    @item.CategoryName
                                                </div>
                                                <div class="prdc_ctg_product_price mt-1 product_price">
                                                    <span class="sale_price pe-1">$@item.Price.ToString("F2")</span>
                                                </div>
                                                <ul class="product_action_btns ul_li_block d-flex">
                                                    <li>
                                                        <a data-bs-toggle="tooltip" data-bs-placement="top" title="Search Product"
                                                           href="#!"><i class="fas fa-search"></i></a>
                                                    </li>
                                                    <li>
                                                        <a data-bs-toggle="tooltip" data-bs-placement="top" title="Add To Cart"
                                                           href="#product_quick_view" data-bs-toggle="modal">
                                                            <i class="fas fa-shopping-bag"></i>
                                                        </a>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="product_sec3_btn text-center mt-5">
                    <a href="#!">
                        <button type="button"
                                class="btn custom_btn rounded-pill px-3 text-white">
                            Explore Now <i class="fas fa-long-arrow-alt-right"></i>
                        </button>
                    </a>
                </div>
                <img class="product3_left_thumb position-absolute"
                     src="/organic-html/assets/images/shapes/shape17.png" alt="image_not_found">
                <img class="product3_right_thumb position-absolute"
                     src="/organic-html/assets/images/shapes/shape18.png" alt="image_not_found">
            </div>
        </div>
    </div>
</section>
